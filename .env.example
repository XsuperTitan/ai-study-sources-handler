QWEN_IMAGE_BASE_URL=https://dashscope.aliyuncs.com
QWEN_IMAGE_MODEL=qwen-image-2.0-pro
QWEN_IMAGE_ENABLED=true
QWEN_IMAGE_FREE_QUOTA_ONLY=true
QWEN_IMAGE_FREE_QUOTA_CONFIRMED=false
